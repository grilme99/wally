    wally.toml: "[package]\nname = \"team/shared-lib\"\nversion = \"0.1.0\"\nlicense = \"MIT\"\nrealm = \"shared\"\nregistry = \"test-registries/primary-registry\"\n"
wally.lock: "# This file is automatically @generated by Wally.\n# It is not intended for manual editing.\nregistry = \"test\"\n\n[[package]]\nname = \"team/server-pkg\"\nversion = \"0.1.0\"\npath = \"modules/server-pkg\"\ndependencies = [\n\t[\"SharedLib\", \"team/shared-lib@0.1.0\"],\n]\n\n[[package]]\nname = \"team/shared-lib\"\nversion = \"0.1.0\"\npath = \"modules/shared-lib\"\ndependencies = []\n\n"
