    wally.toml: "[package]\nname = \"team/server-pkg\"\nversion = \"0.1.0\"\nlicense = \"MIT\"\nrealm = \"server\"\nregistry = \"test-registries/primary-registry\"\n\n[server-dependencies]\nSharedLib = { path = \"../shared-lib\" }\n"
